# === Redirection de l'ancien domaine ===
# flip7.click a déménagé vers kigagne.click. Redirection 301 (permanente) ciblée
# UNIQUEMENT sur ce host : kigagne.click et localhost/MAMP ne sont pas concernés
# (aucune boucle, dev local intact). Doublée par une redirection JS dans
# index.html, car le serveur de flip7.click n'honore peut-être pas ce .htaccess
# (AllowOverride None) — l'app routant par hash, le .htaccess n'y est pas requis.
#
# === Routing SPA + cache (kigagne.click / local) ===
# Sert les vrais fichiers/dossiers ; route le reste vers index.html. Pas de
# RewriteBase : "index.html" se résout dans le dossier du .htaccess, donc le même
# fichier marche à la racine (prod) et en sous-dossier /flip7/ (MAMP).
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Ancien domaine → kigagne.click (préserve le chemin ; le hash est géré en JS).
  RewriteCond %{HTTP_HOST} ^(www\.)?flip7\.click$ [NC]
  RewriteRule ^(.*)$ https://kigagne.click/$1 [R=301,L]

  # Routing SPA : fichiers/dossiers réels servis tels quels, sinon index.html.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  RewriteRule ^ index.html [L]
</IfModule>

# Repli quand mod_rewrite est indisponible mais le .htaccess est honoré : sert
# l'entrée SPA pour tout chemin inconnu. Statut 404 mais l'app démarre et route.
ErrorDocument 404 /index.html

# Toujours revalider le code de l'app : les <meta> HTML ne couvrent pas les
# modules ES importés statiquement, donc sans ceci le navigateur sert des js/css
# périmés. no-store garde chaque chargement frais.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|mjs|css)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
