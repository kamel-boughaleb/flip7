# Ce projet a déménagé vers https://kigagne.click
#
# Redirection 301 (permanente) de TOUTES les URLs vers le nouveau domaine, en
# préservant le chemin (ex: /[lieu]/stats → https://kigagne.click/[lieu]/stats).
# Le 301 indique aux navigateurs et moteurs de recherche que le déplacement est
# définitif : le référencement (SEO) est transféré vers kigagne.click.
#
# La condition sur HTTP_HOST évite toute boucle de redirection si kigagne.click
# venait à être servi par ce même dossier.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} !^kigagne\.click$ [NC]
  RewriteRule ^(.*)$ https://kigagne.click/$1 [R=301,L]
</IfModule>

# Repli si mod_rewrite est indisponible : Redirect préserve aussi le chemin
# restant (ex: /stats → https://kigagne.click/stats).
<IfModule !mod_rewrite.c>
  Redirect 301 / https://kigagne.click/
</IfModule>
